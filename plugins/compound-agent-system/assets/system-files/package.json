{
  "name": "skill-browser",
  "version": "0.8.0",
  "description": "Local browser for Claude Code skills and slash-commands across all installed plugins",
  "type": "module",
  "bin": {
    "skill-browser": "./launch.mjs",
    "skill-browser-mcp": "./mcp-server.mjs",
    "skill-browser-cli": "./cli.mjs",
    "skill-browser-assemble": "./assemble.mjs",
    "skill-browser-handoff": "./handoff-bridge.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "bundle": "node bundle.mjs",
    "test": "bash test.sh",
    "start": "bash launch.sh",
    "e2e": "playwright test"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Robin Westerlund <analys@camjo.se>",
  "keywords": [
    "claude-code",
    "claude",
    "skills",
    "slash-commands",
    "plugin-browser",
    "llm-tools"
  ],
  "files": [
    "build.mjs",
    "bundle.mjs",
    "query.mjs",
    "intent.mjs",
    "kickoff-template.mjs",
    "handoff-bridge.mjs",
    "zip-builder.mjs",
    "assemble.mjs",
    "launch.sh",
    "launch.mjs",
    "index.html",
    "playground.html",
    "assembler.html",
    "hash-router.js",
    "mcp-server.mjs",
    "llm-client.mjs",
    "cli.mjs",
    "recipes.json",
    "frameworks/",
    "schemas/",
    "FUTURE_WORK.md",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@xenova/transformers": "^2.17.2"
  }
}
